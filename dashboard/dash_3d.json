{
  "title": "Pipeline 3D — Anomaly Detection (V1 + MM-PatchCore)",
  "uid": "pfe-pipeline-3d",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "row",
      "title": "API — Pipeline 3D",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2, "type": "stat",
      "title": "Requêtes 3D / seconde",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } } },
      "targets": [{ "expr": "sum(rate(api_http_requests_total{endpoint=~\"/predict/3d.*\"}[1m]))", "legendFormat": "req/s" }]
    },
    {
      "id": 3, "type": "stat",
      "title": "Tâches 3D créées",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "expr": "sum(api_tasks_created_total{pipeline=\"3d\"}) or vector(0)", "legendFormat": "total" }]
    },
    {
      "id": 4, "type": "stat",
      "title": "Modèle V1 (global k-NN)",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } } },
      "targets": [{ "expr": "worker3d_model_cache_version", "legendFormat": "V1 version" }]
    },
    {
      "id": 5, "type": "stat",
      "title": "Modèle V2 (MM-PatchCore)",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 1 }] } } },
      "targets": [{ "expr": "worker3d_model_mm_cache_version", "legendFormat": "V2 version" }]
    },
    {
      "id": 6, "type": "timeseries",
      "title": "Latence API /predict/3d et /predict/3d-mm — P50 / P95",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(api_http_request_duration_seconds_bucket{endpoint=~\"/predict/3d.*\"}[5m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(api_http_request_duration_seconds_bucket{endpoint=~\"/predict/3d.*\"}[5m])) by (le))", "legendFormat": "P95" }
      ]
    },
    {
      "id": 7, "type": "timeseries",
      "title": "Tâches 3D par statut",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "targets": [{ "expr": "api_tasks_by_status{pipeline=\"3d\"}", "legendFormat": "{{status}}" }]
    },
    {
      "id": 10, "type": "row",
      "title": "Worker 3D — Inférence",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 }
    },
    {
      "id": 11, "type": "stat",
      "title": "Tâches traitées 3D",
      "gridPos": { "x": 0, "y": 13, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "expr": "sum(worker3d_tasks_processed_total{status=\"done\"}) or vector(0)", "legendFormat": "done" }]
    },
    {
      "id": 12, "type": "stat",
      "title": "Tâches échouées 3D",
      "gridPos": { "x": 6, "y": 13, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "sum(worker3d_tasks_processed_total{status=\"failed\"}) or vector(0)", "legendFormat": "failed" }]
    },
    {
      "id": 13, "type": "timeseries",
      "title": "Durée d'inférence 3D — P50 / P95",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(worker3d_task_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(worker3d_task_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95" }
      ]
    },
    {
      "id": 14, "type": "timeseries",
      "title": "Tâches 3D traitées / seconde",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "sum(rate(worker3d_tasks_processed_total{status=\"done\"}[1m]))", "legendFormat": "done/s" },
        { "expr": "sum(rate(worker3d_tasks_processed_total{status=\"failed\"}[1m]))", "legendFormat": "failed/s" }
      ]
    },
    {
      "id": 15, "type": "timeseries",
      "title": "Distribution scores anomalie 3D",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(worker3d_anomaly_score_bucket[5m])) by (le))", "legendFormat": "Score P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(worker3d_anomaly_score_bucket[5m])) by (le))", "legendFormat": "Score P95" }
      ]
    }
  ]
}
