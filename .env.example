# ==============================================
# Configuration PFE Anomaly Detection Platform
# ==============================================
# Copier ce fichier en .env et remplir les valeurs

# --- Base de données ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=anomaly_detection
DB_USER=admin
DB_PASS=your_secure_password_here

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- MLflow ---
MLFLOW_TRACKING_URI=https://mlflow.your-domain.com

# --- Images server ---
IMAGES_PUBLIC_BASE=http://images.your-domain.com

# --- SSH Slurm (pour Prefect flows) ---
SSH_JUMP_HOST=ssh.your-school.edu
SLURM_TARGET_IP=10.0.0.1
SLURM_HOST=slurm
SLURM_PORT=22
SLURM_USER=your_username
SLURM_SSH_KEY_PATH=/secrets/slurm/ssh_key
SLURM_PROJECT_DIR=/home/your_user/project
SLURM_MODELS_DIR=/home/your_user/project/models
SLURM_CONDA_ENV=your_env
SLURM_PARTITION=normal
SLURM_GPUS=1
SLURM_CPUS=8
SLURM_MEM=32G
SLURM_TIME=02:00:00

# --- Domains (pour ingress) ---
API_DOMAIN=api.your-domain.com
MLFLOW_DOMAIN=mlflow.your-domain.com
PREFECT_DOMAIN=prefect.your-domain.com
GRAFANA_DOMAIN=grafana.your-domain.com
PROMETHEUS_DOMAIN=prometheus.your-domain.com
ADMINER_DOMAIN=adminer.your-domain.com
IMAGES_DOMAIN=images.your-domain.com
